{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "backend/**/*",
    "Backend/**/*",
    "Jibn-Admin/**/*",
    "node_modules/**/*",
    "backend-*.ts",
    "scripts/**/*"
  ]
}
